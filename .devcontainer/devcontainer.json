{
  "name": "WinCloud — QEMU + Pi-hole",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",

  // ── Container runtime args ────────────────────────────────────────────────
  // --device=/dev/net/tun  → Tailscale & QEMU TAP/TUN networking
  // --device=/dev/kvm      → KVM hardware acceleration for QEMU
  // NET_ADMIN + NET_RAW    → iptables, tun/tap creation, Tailscale MagicDNS
  // SYS_ADMIN              → mount namespaces, swtpm TPM emulation
  // MKNOD                  → create /dev/tpm* nodes for swtpm
  "runArgs": [
    "--device=/dev/net/tun",
    "--device=/dev/kvm",
    "--security-opt=seccomp=unconfined",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=NET_BIND_SERVICE",
    "--cap-add=SYS_ADMIN",
    "--cap-add=SYS_PTRACE",
    "--cap-add=MKNOD"
  ],

  // ── Lifecycle ─────────────────────────────────────────────────────────────
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y software-properties-common && sudo add-apt-repository -y universe && sudo apt-get update && sudo apt-get install -y qemu-system-x86 qemu-utils ovmf swtpm qemu-kvm wget git && bash .devcontainer/setup.sh 2>&1 | tee /tmp/devcontainer-setup.log",

  // ── Forwarded ports ───────────────────────────────────────────────────────
  "forwardPorts": [80, 5900, 5901, 3389],
  "portsAttributes": {
    "80":   { "label": "Pi-hole Admin",  "onAutoForward": "notify" },
    "5900": { "label": "SPICE",          "onAutoForward": "silent" },
    "5901": { "label": "VNC",            "onAutoForward": "silent" },
    "3389": { "label": "RDP",            "onAutoForward": "silent" }
  },

  "remoteUser": "root"
}
